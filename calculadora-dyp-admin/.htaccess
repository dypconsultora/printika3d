# La pagina de inicio es la calculadora (protegida por login)
DirectoryIndex index.php

# No mostrar el listado de archivos de la carpeta
Options -Indexes

# Evitar que se descarguen archivos sensibles
<FilesMatch "^(config\.php|db\.php|auth\.php)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</FilesMatch>
